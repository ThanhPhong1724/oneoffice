# ============================================================
#  OneOffice (Wonderland Việt Nam) — .gitignore
#  Bản backup toàn bộ website (WP Core, Plugins, Themes, Uploads, DB)
# ============================================================

# 1) Loại trừ log và log của các plugin
*.log
error_log
wp-content/debug.log
wp-content/wc-logs/
wp-content/wflogs/

# 2) Loại trừ cache và các thư mục nâng cấp tạm thời
wp-content/cache/
wp-content/upgrade/

# 3) Loại trừ các file nén dung lượng lớn (các gói backup cũ)
*.zip
*.daf
*.tar.gz
*.rar
*.7z
wp-content/ew-backup/
wp-snapshots/

# 4) Loại trừ file cấu hình IDE và các file tạm của lập trình viên
.idea/
.vscode/
.playwright-mcp/
.gemini/
_inventory_*.txt
*.bak
*.oo-bak
*_backup/
*_backups/
scratch/

# 5) Cho phép và lưu trữ Database backup
!database/
!database/db_backup.sql
